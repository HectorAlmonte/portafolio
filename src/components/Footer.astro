---
import { type Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer style="padding:32px 56px;border-top:1px solid var(--rule);background:var(--bg-dark)">
  <div style="display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--muted);gap:24px;flex-wrap:wrap">
    <div>
      <span style="color:var(--accent)">➜ ~ </span>
      echo "Made with care — Astro + Tailwind · v2026.1"
    </div>
    <div style="display:flex;gap:18px">
      <a href="https://github.com/HectorAlmonte" target="_blank" rel="noopener"
        style="color:var(--accent);text-decoration:none">github↗</a>
      <a href="https://www.linkedin.com/in/hector-almonte-788a4a212/" target="_blank" rel="noopener"
        style="color:var(--accent);text-decoration:none">linkedin↗</a>
      <a href="mailto:hectoralmonte.dev@gmail.com"
        style="color:var(--accent);text-decoration:none">hectoralmonte.dev@gmail.com</a>
    </div>
  </div>
</footer>
