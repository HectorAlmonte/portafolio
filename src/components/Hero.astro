---
import { type Lang } from '../i18n/translations';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const bioLines = t.hero.bio.split('\n');
---

<section class="max-w-5xl mx-auto px-6 py-24 min-h-[80vh] flex flex-col justify-center">
  <!-- Terminal window header -->
  <div class="terminal-card max-w-2xl">
    <div class="flex items-center gap-2 mb-6 pb-4 border-b border-terminal-border">
      <span class="w-3 h-3 rounded-full bg-terminal-red"></span>
      <span class="w-3 h-3 rounded-full bg-terminal-yellow"></span>
      <span class="w-3 h-3 rounded-full bg-terminal-green"></span>
      <span class="ml-2 text-xs text-terminal-muted">bash — portfolio</span>
    </div>

    <!-- Terminal content -->
    <div class="space-y-3 text-sm">
      <div class="flex gap-2">
        <span class="prompt">➜</span>
        <span class="comment">~</span>
        <span class="cmd">whoami</span>
      </div>

      <div class="pl-4 animate-[fadeIn_0.5s_ease_0.3s_forwards] opacity-0">
        <p class="text-2xl sm:text-3xl font-bold text-terminal-text">
          Hector
        </p>
        <p class="text-terminal-cyan mt-1">Full Stack Developer</p>
      </div>

      <div class="flex gap-2 mt-4 animate-[fadeIn_0.5s_ease_0.6s_forwards] opacity-0">
        <span class="prompt">➜</span>
        <span class="comment">~</span>
        <span class="cmd">cat bio.txt</span>
      </div>

      <div class="pl-4 text-terminal-muted leading-relaxed animate-[fadeIn_0.5s_ease_0.9s_forwards] opacity-0">
        {bioLines.map((line, i) => (
          <span>{line}{i < bioLines.length - 1 && <br />}</span>
        ))}
      </div>

      <div class="flex gap-2 mt-4 animate-[fadeIn_0.5s_ease_1.2s_forwards] opacity-0">
        <span class="prompt">➜</span>
        <span class="comment">~</span>
        <span class="cmd">ls skills/</span>
      </div>

      <div class="pl-4 flex flex-wrap gap-2 animate-[fadeIn_0.5s_ease_1.5s_forwards] opacity-0">
        {['TypeScript', 'React', 'Node.js', 'PostgreSQL', 'Docker', 'Astro'].map(skill => (
          <span class="tag">{skill}</span>
        ))}
      </div>

      <div class="flex gap-2 mt-4 animate-[fadeIn_0.5s_ease_1.8s_forwards] opacity-0">
        <span class="prompt">➜</span>
        <span class="comment">~</span>
        <span class="text-terminal-green animate-blink">▋</span>
      </div>
    </div>
  </div>

  <!-- CTA buttons -->
  <div class="mt-8 flex flex-wrap gap-4 animate-[fadeIn_0.5s_ease_2.1s_forwards] opacity-0">
    <a
      href={`/${lang}/projects`}
      class="px-5 py-2.5 bg-terminal-green text-terminal-bg font-semibold rounded hover:bg-terminal-green/90 transition-colors text-sm"
    >
      {t.hero.viewProjects}
    </a>
    <a
      href={`/${lang}/contact`}
      class="px-5 py-2.5 border border-terminal-border text-terminal-muted hover:text-terminal-text hover:border-terminal-muted rounded transition-colors text-sm"
    >
      {t.hero.contact}
    </a>
  </div>
</section>
