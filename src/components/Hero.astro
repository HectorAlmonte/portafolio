---
import { type Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const blurb = lang === 'es'
  ? 'Desarrollador Full Stack con 4+ años construyendo sistemas web y de escritorio. Actualmente Supervisor de Sistemas en <strong>Global Plus</strong>, Ilo, Perú.'
  : 'Full Stack Developer with 4+ years building web and desktop systems. Currently Systems Supervisor at <strong>Global Plus</strong>, Ilo, Peru.';

const helpLabel  = lang === 'es' ? 'quién soy' : 'who I am';
const stackLabel = lang === 'es' ? 'stack principal' : 'primary stack';
const stack = ['JavaScript', 'TypeScript', 'React', 'Node.js', 'ASP.NET', 'SQL Server', '.NET C#'];

const helpCmds = [
  { c: 'whoami',    d: lang === 'es' ? 'quién soy' : 'who I am' },
  { c: 'about',     d: lang === 'es' ? 'sobre mí' : 'about me' },
  { c: 'projects',  d: lang === 'es' ? 'proyectos destacados' : 'featured projects' },
  { c: 'stack',     d: lang === 'es' ? 'tecnologías que uso' : 'technologies I use' },
  { c: 'contact',   d: lang === 'es' ? 'cómo escribirme' : 'how to reach me' },
  { c: 'cv',        d: lang === 'es' ? 'descargar mi CV' : 'download my CV' },
  { c: 'clear',     d: lang === 'es' ? 'limpiar terminal' : 'clear terminal' },
];

const nowBuilding = lang === 'es' ? 'Construyendo PWA de seguridad industrial' : 'Building industrial safety PWA';
const nowLearning = lang === 'es' ? 'aprendiendo Rust en tardes' : 'learning Rust in evenings';
const nowReading  = lang === 'es' ? 'leyendo "Designing Data-Intensive Apps"' : 'reading "Designing Data-Intensive Apps"';

const viewProjects = lang === 'es' ? './ver-proyectos.sh →' : './view-projects.sh →';
const mailLabel    = '$ mailto:hector';
const cvLabel      = 'wget cv.pdf ↓';
---

<!-- ── HERO ────────────────────────────────────────────────── -->
<section style="padding:64px 56px 32px;position:relative;overflow:hidden">
  <div class="tm-vignette"></div>
  <div class="tm-scan"></div>

  <!-- prompt line -->
  <div class="tm-fade-in" style="display:flex;gap:12px;align-items:baseline;margin-bottom:24px;position:relative;z-index:1;animation:tm-fade-in .5s cubic-bezier(.2,.7,.2,1) both">
    <span style="color:var(--accent)">➜</span>
    <span style="color:var(--muted)">~</span>
    <span style="color:var(--ink)">whoami</span>
    <span class="tm-cursor" style="color:var(--accent)"></span>
  </div>

  <!-- 2-col grid -->
  <div style="display:grid;grid-template-columns:7fr 5fr;gap:56px;align-items:start;position:relative;z-index:1" class="hero-grid">

    <!-- LEFT -->
    <div>
      <h1 class="tm-display" style="font-size:clamp(56px,9vw,100px);line-height:.95;margin:0">
        <span style="color:var(--muted)">{'>'}</span>
        <span style="color:var(--ink)"> hector</span><br/>
        <span class="tm-typed" style="color:var(--accent)">almonte</span><span style="color:var(--muted)">.</span><span class="sans" style="font-style:italic;color:var(--ink-soft)">dev</span>
      </h1>

      <p class="sans" style="margin-top:32px;font-size:17px;color:var(--ink-soft);max-width:600px;line-height:1.55" set:html={blurb.replace('<strong>', `<strong style="color:var(--accent)">`)}></p>

      <!-- Interactive terminal REPL -->
      <div class="tm-panel" style="margin-top:32px;padding:0;overflow:hidden" id="hero-repl">
        <!-- Terminal chrome -->
        <div style="display:flex;align-items:center;gap:8px;padding:10px 14px;border-bottom:1px solid var(--rule);font-size:11px;color:var(--muted)">
          <span style="display:flex;gap:5px">
            <span style="width:9px;height:9px;border-radius:5px;background:#ff5f57;display:block"></span>
            <span style="width:9px;height:9px;border-radius:5px;background:#febc2e;display:block"></span>
            <span style="width:9px;height:9px;border-radius:5px;background:#28c840;display:block"></span>
          </span>
          <span style="margin-left:8px">bash — portfolio · ~/hector</span>
          <span style="flex:1"></span>
          <span style="color:var(--accent);font-size:10px">● interactive · {lang === 'es' ? 'prueba: help' : 'try: help'}</span>
        </div>
        <!-- Output area -->
        <div id="repl-output" style="padding:14px 16px;font-size:13px;line-height:1.7;color:var(--ink-soft);max-height:220px;overflow-y:auto;font-family:'JetBrains Mono',monospace;cursor:text">
          <!-- Initial history injected by JS -->
        </div>
        <!-- Input -->
        <form id="repl-form" style="display:flex;align-items:center;gap:8px;padding:4px 16px 14px">
          <span style="color:var(--accent)">➜ ~</span>
          <input
            id="repl-input"
            type="text"
            autocomplete="off"
            spellcheck="false"
            placeholder={lang === 'es' ? "escribe 'help' …" : "type 'help' …"}
            style="background:transparent;border:0;outline:0;flex:1;color:var(--ink);font:inherit;padding:0;caret-color:var(--accent)"
          />
        </form>
      </div>

      <!-- CTA buttons -->
      <div style="display:flex;gap:8px;margin-top:24px;flex-wrap:wrap">
        <a href={`/${lang}/projects`}
          style="padding:11px 18px;background:var(--accent-dim);color:var(--bg);border-radius:4px;font-size:13px;font-weight:600;border:0;cursor:pointer;font-family:inherit;text-decoration:none;transition:background .15s,box-shadow .15s"
          onmouseover="this.style.background='var(--accent)';this.style.boxShadow='0 0 0 4px #a6f55b22'"
          onmouseout="this.style.background='var(--accent-dim)';this.style.boxShadow='none'"
        >
          {viewProjects}
        </a>
        <a href={`/${lang}/contact`}
          style="padding:11px 18px;border:1px solid var(--rule);border-radius:4px;font-size:13px;color:var(--ink);background:transparent;cursor:pointer;font-family:inherit;text-decoration:none;transition:border-color .15s,color .15s"
          onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'"
          onmouseout="this.style.borderColor='var(--rule)';this.style.color='var(--ink)'"
        >
          {mailLabel}
        </a>
        <a href="/hector-almonte-cv.pdf" download
          style="padding:11px 18px;border-radius:4px;font-size:13px;color:var(--muted);text-decoration:none;display:inline-block">
          {cvLabel}
        </a>
      </div>
    </div>

    <!-- RIGHT RAIL -->
    <div style="display:flex;flex-direction:column;gap:16px;margin-top:80px" class="hero-rail">

      <!-- Uptime + sparkline -->
      <div class="tm-panel" style="padding:18px 20px">
        <div style="font-size:11px;color:var(--muted);margin-bottom:8px">$ uptime</div>
        <div style="display:flex;align-items:baseline;gap:6px">
          <span class="tm-display" style="font-size:56px;color:var(--accent)">4</span>
          <span style="color:var(--muted);font-size:13px">{lang === 'es' ? 'años, 4 meses' : 'years, 4 months'}</span>
        </div>
        <div class="sans" style="font-size:12px;color:var(--ink-soft);margin-top:6px">
          {lang === 'es' ? 'shipping software desde dic 2021' : 'shipping software since dec 2021'}
        </div>
        <div style="margin-top:14px">
          <div style="font-size:10px;color:var(--muted);margin-bottom:6px;display:flex;justify-content:space-between">
            <span>{lang === 'es' ? 'commits · last 52w' : 'commits · last 52w'}</span>
            <span>1,284</span>
          </div>
          <div id="sparkline" style="height:36px;display:flex;align-items:flex-end">
            <!-- bars injected by JS -->
          </div>
        </div>
      </div>

      <!-- ls --status -->
      <div class="tm-panel" style="padding:18px 20px">
        <div style="font-size:11px;color:var(--muted);margin-bottom:10px">$ ls --status</div>
        <div style="display:flex;flex-direction:column;gap:9px;font-size:13px">
          <div style="display:flex;justify-content:space-between">
            <span style="color:var(--ink-soft)">open-to-work</span>
            <span style="color:var(--accent)">● true</span>
          </div>
          <div style="display:flex;justify-content:space-between">
            <span style="color:var(--ink-soft)">relocate</span>
            <span style="color:var(--warn)">~ remoto-first</span>
          </div>
          <div style="display:flex;justify-content:space-between">
            <span style="color:var(--ink-soft)">response-time</span>
            <span style="color:var(--ink)">{'< 24h'}</span>
          </div>
          <div style="display:flex;justify-content:space-between">
            <span style="color:var(--ink-soft)">english</span>
            <span style="color:var(--ink)">B2/C1 técnico</span>
          </div>
          <div style="display:flex;justify-content:space-between">
            <span style="color:var(--ink-soft)">availability</span>
            <span style="color:var(--ink)">full-time · 2026</span>
          </div>
        </div>
      </div>

      <!-- git log -->
      <div class="tm-panel" style="padding:18px 20px">
        <div style="font-size:11px;color:var(--muted);margin-bottom:10px">$ git log --recent</div>
        <div style="display:flex;flex-direction:column;gap:10px;font-size:12px">
          <div>
            <div style="color:var(--accent)">feat(gre): scan ADR diamond via OCR</div>
            <div style="color:var(--muted);font-size:11px">3d · gre-materiales</div>
          </div>
          <div>
            <div style="color:var(--accent)">fix(rindex): timer rounding edge case</div>
            <div style="color:var(--muted);font-size:11px">1w · rindex</div>
          </div>
          <div>
            <div style="color:var(--accent)">docs: postmortem on telemetry outage</div>
            <div style="color:var(--muted);font-size:11px">2w · agrosoft-fleet</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr !important; gap: 40px !important; }
    .hero-rail { margin-top: 0 !important; }
    section { padding: 40px 24px 24px !important; }
  }
</style>

<script define:vars={{ lang, helpCmds, stack }}>
  document.addEventListener('astro:page-load', () => {
    const outputEl = document.getElementById('repl-output');
    const form     = document.getElementById('repl-form');
    const inputEl  = document.getElementById('repl-input');
    if (!outputEl || !form || !inputEl) return;

    const TM = {
      accent:  'var(--accent)',
      muted:   'var(--muted)',
      ink:     'var(--ink)',
      inkSoft: 'var(--ink-soft)',
      warn:    'var(--warn)',
    };

    // history = [{type:'cmd'|'out'|'err', text:string}]
    let history = [
      { type: 'cmd', text: 'whoami' },
      { type: 'out', text: 'Hector Almonte · Full Stack Developer' },
      { type: 'out', text: 'Ilo, Perú · GMT−05:00' },
    ];

    function render() {
      outputEl.innerHTML = history.map(h => {
        const color = h.type === 'err' ? TM.warn : h.type === 'cmd' ? TM.ink : TM.inkSoft;
        const prefix = h.type === 'cmd'
          ? `<span style="color:${TM.accent}">➜ ~ </span>`
          : '';
        return `<div style="color:${color};white-space:pre-wrap">${prefix}${h.text}</div>`;
      }).join('');
      outputEl.scrollTop = outputEl.scrollHeight;
    }

    function run(raw) {
      const cmd = raw.trim().toLowerCase();
      if (!cmd) return;
      const next = [...history, { type: 'cmd', text: raw }];

      if (cmd === 'help' || cmd === '?') {
        helpCmds.forEach(h => next.push({ type: 'out', text: `  ${h.c.padEnd(12)} ${h.d}` }));
      } else if (cmd === 'whoami') {
        next.push({ type: 'out', text: 'Hector Almonte · Full Stack Developer · Ilo, Perú' });
      } else if (cmd === 'about') {
        next.push({ type: 'out', text: `opening ~/about ...` });
        setTimeout(() => { window.location.href = `/${lang}/about`; }, 400);
      } else if (cmd === 'projects' || cmd === 'ls projects') {
        [
          '  ★ gre-materiales       2025  PWA para 2,661 materiales peligrosos (GRE 2024)',
          '  ★ rindex               2024  Plataforma de evaluación académica',
        ].forEach(t => next.push({ type: 'out', text: t }));
        next.push({ type: 'out', text: `  → navega a "projects" arriba` });
      } else if (cmd === 'stack') {
        next.push({ type: 'out', text: `  ${stack.join('  ')}` });
      } else if (cmd === 'contact') {
        next.push({ type: 'out', text: `opening ~/contact ...` });
        setTimeout(() => { window.location.href = `/${lang}/contact`; }, 400);
      } else if (cmd === 'cv') {
        next.push({ type: 'out', text: 'downloading hector-almonte-cv.pdf ...' });
        const a = document.createElement('a');
        a.href = '/hector-almonte-cv.pdf';
        a.download = 'hector-almonte-cv.pdf';
        a.click();
      } else if (cmd === 'clear' || cmd === 'cls') {
        history = [];
        inputEl.value = '';
        render();
        return;
      } else if (cmd === 'sudo rm -rf /') {
        next.push({ type: 'err', text: 'nice try 😄' });
      } else {
        next.push({ type: 'err', text: `command not found: ${raw}  ·  try 'help'` });
      }

      history = next;
      inputEl.value = '';
      render();
    }

    form.addEventListener('submit', e => { e.preventDefault(); run(inputEl.value); });
    outputEl.addEventListener('click', () => inputEl.focus());
    render();

    // Sparkline
    const sparkEl = document.getElementById('sparkline');
    if (sparkEl) {
      sparkEl.innerHTML = Array.from({ length: 52 }, (_, i) => {
        const seed = Math.sin(i * 1.7) * 0.5 + Math.cos(i * 0.6) * 0.3 + 0.5;
        const h = Math.max(4, Math.min(34, seed * 34 + (i > 40 ? 6 : 0)));
        const opacity = (0.35 + (h / 34) * 0.65).toFixed(2);
        return `<span class="spark-bar" style="height:${h}px;animation-delay:${i * 18}ms;opacity:${opacity}"></span>`;
      }).join('');
    }
  });
</script>
