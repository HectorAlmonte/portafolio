---
import { type Lang } from '../i18n/translations';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const bioLines = t.hero.bio.split('\n');
---

<!-- Full-width hero with matrix rain behind -->
<section class="relative overflow-hidden min-h-[90vh] flex flex-col justify-center">

  <!-- Matrix rain canvas -->
  <canvas id="matrix-canvas" class="absolute inset-0 w-full h-full"></canvas>

  <!-- Gradient overlays: left vignette + bottom fade -->
  <div class="absolute inset-0 bg-gradient-to-r from-terminal-bg/60 via-transparent to-terminal-bg/60 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-terminal-bg to-transparent pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 py-24 flex flex-col justify-center w-full">

    <!-- Terminal window -->
    <div class="terminal-card max-w-2xl shadow-2xl shadow-terminal-green/5">
      <div class="flex items-center gap-2 mb-6 pb-4 border-b border-terminal-border">
        <span class="w-3 h-3 rounded-full bg-terminal-red"></span>
        <span class="w-3 h-3 rounded-full bg-terminal-yellow"></span>
        <span class="w-3 h-3 rounded-full bg-terminal-green"></span>
        <span class="ml-2 text-xs text-terminal-muted">bash — portfolio</span>
      </div>

      <div class="space-y-3 text-sm" id="terminal-content">
        <!-- Line 1: whoami -->
        <div class="flex gap-2">
          <span class="prompt">➜</span>
          <span class="comment">~</span>
          <span class="cmd" id="cmd-1"></span>
          <span class="text-terminal-green" id="cursor-1">▋</span>
        </div>

        <!-- whoami response -->
        <div class="pl-4 opacity-0 transition-opacity duration-500" id="resp-1">
          <p class="text-2xl sm:text-3xl font-bold text-terminal-text">Hector</p>
          <p class="text-terminal-cyan mt-1">Full Stack Developer</p>
        </div>

        <!-- Line 2: cat bio.txt -->
        <div class="flex gap-2 opacity-0" id="line-2">
          <span class="prompt">➜</span>
          <span class="comment">~</span>
          <span class="cmd" id="cmd-2"></span>
          <span class="text-terminal-green" id="cursor-2">▋</span>
        </div>

        <!-- bio response -->
        <div class="pl-4 text-terminal-muted leading-relaxed opacity-0 transition-opacity duration-500" id="resp-2">
          {bioLines.map((line, i) => (
            <span>{line}{i < bioLines.length - 1 && <br />}</span>
          ))}
        </div>

        <!-- Line 3: ls skills/ -->
        <div class="flex gap-2 opacity-0" id="line-3">
          <span class="prompt">➜</span>
          <span class="comment">~</span>
          <span class="cmd" id="cmd-3"></span>
          <span class="text-terminal-green" id="cursor-3">▋</span>
        </div>

        <!-- skills response -->
        <div class="pl-4 flex flex-wrap gap-2 opacity-0 transition-opacity duration-500" id="resp-3">
          {['JavaScript', 'TypeScript', 'React', 'Node.js', 'ASP.NET', 'SQL Server', '.NET C#'].map(skill => (
            <span class="tag">{skill}</span>
          ))}
        </div>

        <!-- Final blinking cursor -->
        <div class="flex gap-2 opacity-0" id="line-final">
          <span class="prompt">➜</span>
          <span class="comment">~</span>
          <span class="text-terminal-green animate-blink">▋</span>
        </div>
      </div>
    </div>

    <!-- CTA buttons -->
    <div class="mt-8 flex flex-wrap gap-4 opacity-0 transition-opacity duration-500" id="cta-buttons">
      <a
        href={`/${lang}/projects`}
        class="px-5 py-2.5 bg-terminal-green text-terminal-bg font-semibold rounded hover:bg-terminal-green/90 transition-colors text-sm"
      >
        {t.hero.viewProjects}
      </a>
      <a
        href={`/${lang}/contact`}
        class="px-5 py-2.5 border border-terminal-border text-terminal-muted hover:text-terminal-text hover:border-terminal-muted rounded transition-colors text-sm"
      >
        {t.hero.contact}
      </a>
      <a
        href="/hector-almonte-cv.pdf"
        download
        class="px-5 py-2.5 border border-terminal-green/50 text-terminal-green hover:bg-terminal-green hover:text-terminal-bg rounded transition-colors text-sm"
      >
        ↓ {lang === 'es' ? 'Descargar CV' : 'Download CV'}
      </a>
    </div>

  </div>
</section>

<script>
  /* ── Matrix rain ─────────────────────────────────────────── */
  (function initMatrix() {
    const canvas = document.getElementById('matrix-canvas') as HTMLCanvasElement;
    const ctx    = canvas.getContext('2d')!;

    const CHARS  = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789<>{}[]|/\\=+-*ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';
    const FS     = 13;   // font size
    const SPEED  = 2;    // frames to skip (higher = slower rain)
    const GREEN  = '#39d353';
    const BG     = '#0d1117';

    let cols: number[] = [];
    let frame = 0;

    function resize() {
      canvas.width  = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
      cols = Array.from({ length: Math.floor(canvas.width / FS) }, () =>
        Math.floor(Math.random() * -50)
      );
    }

    function draw() {
      frame++;
      requestAnimationFrame(draw);
      if (frame % SPEED !== 0) return;

      // Fade trail
      ctx.fillStyle = `rgba(13,17,23,0.07)`;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.font = `${FS}px "JetBrains Mono", monospace`;

      cols.forEach((y, i) => {
        const ch  = CHARS[Math.floor(Math.random() * CHARS.length)];
        const x   = i * FS;
        const yPx = y * FS;

        // Head character: bright white
        ctx.fillStyle = 'rgba(200,255,200,0.9)';
        ctx.fillText(ch, x, yPx);

        // One step behind: slightly dimmer green
        ctx.fillStyle = 'rgba(57,211,83,0.6)';
        ctx.fillText(CHARS[Math.floor(Math.random() * CHARS.length)], x, yPx - FS);

        // Reset column
        if (yPx > canvas.height && Math.random() > 0.975) cols[i] = 0;
        cols[i]++;
      });
    }

    resize();
    window.addEventListener('resize', resize);
    requestAnimationFrame(draw);
  })();

  /* ── Typewriter ──────────────────────────────────────────── */
  function typeText(el: HTMLElement, text: string, speed = 55): Promise<void> {
    return new Promise(resolve => {
      let i = 0;
      const tick = setInterval(() => {
        el.textContent += text[i++];
        if (i >= text.length) { clearInterval(tick); resolve(); }
      }, speed);
    });
  }

  function show(el: HTMLElement) { el.style.opacity = '1'; }
  function hide(el: HTMLElement) { el.style.display = 'none'; }
  const delay = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

  async function runTerminal() {
    const cmd1    = document.getElementById('cmd-1')!;
    const cur1    = document.getElementById('cursor-1')!;
    const resp1   = document.getElementById('resp-1')!;
    const line2   = document.getElementById('line-2')!;
    const cmd2    = document.getElementById('cmd-2')!;
    const cur2    = document.getElementById('cursor-2')!;
    const resp2   = document.getElementById('resp-2')!;
    const line3   = document.getElementById('line-3')!;
    const cmd3    = document.getElementById('cmd-3')!;
    const cur3    = document.getElementById('cursor-3')!;
    const resp3   = document.getElementById('resp-3')!;
    const lineFin = document.getElementById('line-final')!;
    const cta     = document.getElementById('cta-buttons')!;

    await delay(600);

    await typeText(cmd1, 'whoami');
    hide(cur1);
    await delay(150);
    show(resp1);
    await delay(500);

    show(line2);
    await typeText(cmd2, 'cat bio.txt');
    hide(cur2);
    await delay(150);
    show(resp2);
    await delay(500);

    show(line3);
    await typeText(cmd3, 'ls skills/');
    hide(cur3);
    await delay(150);
    show(resp3);
    await delay(400);

    show(lineFin);
    await delay(200);
    show(cta);
  }

  runTerminal();
</script>
