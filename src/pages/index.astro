---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';

const featuredProjects = [
  {
    title: 'project-alpha',
    description: 'Aplicación full stack con autenticación, API REST y dashboard en tiempo real.',
    tech: ['React', 'Node.js', 'PostgreSQL', 'Docker'],
    github: '#',
    demo: '#',
    featured: true,
  },
  {
    title: 'project-beta',
    description: 'E-commerce con carrito, pagos y panel de administración.',
    tech: ['Next.js', 'Stripe', 'Prisma', 'TailwindCSS'],
    github: '#',
    demo: '#',
  },
];
---

<Layout title="Home">
  <Hero />

  <!-- Featured projects preview -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="flex items-center justify-between mb-8">
      <div>
        <span class="text-terminal-green text-sm">$</span>
        <span class="text-terminal-muted text-sm ml-2">ls ~/projects --featured</span>
      </div>
      <a href="/projects" class="text-xs text-terminal-muted hover:text-terminal-cyan transition-colors">
        ver todos →
      </a>
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      {featuredProjects.map(project => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>
</Layout>
