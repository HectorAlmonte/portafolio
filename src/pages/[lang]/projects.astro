---
import Layout from '../../layouts/Layout.astro';
import { languages, type Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return languages.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const projects = [
  {
    id: 'gre-materiales', title: 'gre-materiales', year: '2025',
    kind: lang === 'es' ? 'producto propio · PWA' : 'own product · PWA',
    featured: true,
    tagline: lang === 'es'
      ? 'Sistema PWA para consulta de 2,661 materiales peligrosos (GRE 2024). Búsqueda en tiempo real, escáner OCR, modo offline.'
      : 'PWA for consulting 2,661 hazardous materials (ERG 2024). Real-time search, OCR scanner, offline mode.',
    stack: ['Next.js 16', 'TypeScript', 'PostgreSQL', 'PWA', 'Tesseract.js'],
    github: 'https://github.com/HectorAlmonte',
  },
  {
    id: 'rindex', title: 'rindex', year: '2024',
    kind: lang === 'es' ? 'SaaS académico' : 'academic SaaS',
    featured: true,
    tagline: lang === 'es'
      ? 'Plataforma de evaluación académica con 3 roles, exámenes temporizados y análisis de rendimiento.'
      : 'Academic evaluation platform with 3 roles, timed exams, and performance analytics.',
    stack: ['Next.js 14', 'TypeScript', 'Prisma', 'PostgreSQL', 'NextAuth'],
    github: 'https://github.com/HectorAlmonte',
  },
  {
    id: 'agrosoft-fleet', title: 'agrosoft-fleet', year: '2022–2025',
    kind: lang === 'es' ? 'trabajo · sistema interno' : 'work · internal system',
    featured: false,
    tagline: lang === 'es'
      ? 'Monitoreo en tiempo real de maquinaria agrícola con visualización geoespacial. GPS, alertas, telemetría.'
      : 'Real-time agricultural machinery monitoring with geospatial visualization. GPS, alerts, telemetry.',
    stack: ['React', '.NET C#', 'SQL Server', 'Mapbox'],
    github: 'https://github.com/HectorAlmonte',
  },
  {
    id: 'industrial-safety', title: 'industrial-safety', year: '2025',
    kind: lang === 'es' ? 'trabajo · Global Plus' : 'work · Global Plus',
    featured: false,
    tagline: lang === 'es'
      ? 'Sistema de gestión de riesgos para almacenaje de materiales peligrosos. Protocolos, control operativo, multi-rol.'
      : 'Risk management system for hazardous materials storage. Protocols, operational control, multi-role.',
    stack: ['Next.js', 'PostgreSQL', 'Docker', 'PWA'],
    github: 'https://github.com/HectorAlmonte',
  },
  {
    id: 'bj-architect', title: 'bj-architect', year: '2024',
    kind: lang === 'es' ? 'herramienta personal' : 'personal tool',
    featured: false,
    tagline: lang === 'es'
      ? 'Asistente de estrategia para Blackjack en tiempo real. Motor de decisión óptima con historial de sesión.'
      : 'Real-time Blackjack strategy assistant. Optimal decision engine with session history.',
    stack: ['Next.js 16', 'TypeScript', 'SQLite', 'Drizzle ORM'],
    github: 'https://github.com/HectorAlmonte',
  },
  {
    id: 'portfolio', title: 'portfolio', year: '2024',
    kind: lang === 'es' ? 'proyecto personal' : 'personal project',
    featured: false,
    tagline: lang === 'es'
      ? 'Este portafolio. Astro 5, TailwindCSS, tema Terminal Evolved, soporte bilingüe ES/EN.'
      : 'This portfolio. Astro 5, TailwindCSS, Terminal Evolved theme, ES/EN bilingual support.',
    stack: ['Astro 5', 'TailwindCSS', 'TypeScript', 'EmailJS'],
    github: 'https://github.com/HectorAlmonte/portafolio',
    demo: 'https://portafolio-eight-self-36.vercel.app',
  },
];

const heroTitle = lang === 'es' ? 'projects/all' : 'projects/all';
const heroDesc  = lang === 'es'
  ? 'Una selección de software que terminó en producción y aguantó. Productos propios, trabajos internos, freelance. Todos tienen al menos un usuario que no soy yo.'
  : 'A selection of software that made it to production and stuck around. Own products, internal work, freelance. All have at least one user who isn\'t me.';

const colYear    = 'year';
const colProject = 'project';
const colSummary = lang === 'es' ? 'descripción' : 'summary';
const colStack   = 'stack';
---

<Layout title={t.projects.title} description={t.meta.projects} lang={lang}>

  <!-- HEADER -->
  <section style="padding:64px 56px 32px" class="proj-header">
    <div style="font-size:11px;color:var(--muted);margin-bottom:12px">
      <span style="color:var(--accent)">$</span> ls ~/projects --all
      <span style="color:var(--rule-soft)"> · </span>
      <span style="color:var(--muted)">// N.º 03</span>
    </div>
    <h1 class="tm-display" style="font-size:clamp(56px,8vw,96px);margin:0;line-height:.95">
      <span style="color:var(--muted)">{'>'}</span>
      <span style="color:var(--ink)"> projects</span><span style="color:var(--muted)">/</span><span class="sans" style="font-style:italic;color:var(--accent)">all</span>
      <span class="tm-cursor" style="color:var(--accent)"></span>
    </h1>
    <p class="sans" style="margin-top:32px;font-size:18px;color:var(--ink-soft);max-width:780px;line-height:1.5">
      {heroDesc}
    </p>
  </section>

  <!-- TOOLBAR -->
  <section style="padding:20px 56px;border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);background:var(--bg-dark)" class="proj-toolbar">
    <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
      <span style="font-size:11px;color:var(--muted)">$ filter --by</span>
      <div style="display:flex;gap:6px;flex-wrap:wrap" id="filter-btns">
        {[
          { id: 'all',      label: 'all',      n: projects.length },
          { id: 'featured', label: 'featured', n: projects.filter(p => p.featured).length },
          { id: 'producto', label: 'producto', n: projects.filter(p => p.kind.includes('producto')).length },
          { id: 'trabajo',  label: 'trabajo',  n: projects.filter(p => p.kind.includes('trabajo')).length },
        ].map(f => (
          <button
            data-filter={f.id}
            class="filter-chip"
            style={`padding:6px 14px;border-radius:999px;border:1px solid var(--rule);background:${f.id === 'all' ? 'var(--accent)' : 'transparent'};color:${f.id === 'all' ? 'var(--bg)' : 'var(--ink-soft)'};cursor:pointer;font-family:inherit;font-size:12px;transition:background .15s,color .15s,border-color .15s;${f.id === 'all' ? 'font-weight:600;border-color:var(--accent)' : ''}`}
          >
            {f.label} <span style="opacity:.6;margin-left:4px">{f.n}</span>
          </button>
        ))}
      </div>
      <span style="flex:1"></span>
      <a href="https://github.com/HectorAlmonte" target="_blank" rel="noreferrer"
        style="font-size:12px;color:var(--accent);text-decoration:none">
        github.com/HectorAlmonte ↗
      </a>
    </div>
  </section>

  <!-- INDEX TABLE -->
  <section style="padding:24px 56px 80px" class="proj-list">
    <!-- Column headers -->
    <div style="padding:14px 0;display:grid;grid-template-columns:96px 1.6fr 2.2fr 1.4fr 32px;gap:24px;font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--rule)" class="proj-cols">
      <span>{colYear}</span><span>{colProject}</span><span>{colSummary}</span><span>{colStack}</span><span>→</span>
    </div>

    <!-- Rows -->
    {projects.map(p => (
      <a
        href={`/${lang}/projects/${p.id}`}
        class="proj-row proj-cols"
        data-kind={p.kind}
        data-featured={String(p.featured)}
        style="grid-template-columns:96px 1.6fr 2.2fr 1.4fr 32px"
      >
        <div class="tm-display proj-row-year" style="font-size:28px;color:var(--ink);line-height:1;letter-spacing:-.02em">
          {String(p.year).slice(-4)}
        </div>
        <div>
          <div class="proj-row-title tm-display" style="font-size:20px;color:var(--ink);letter-spacing:-.02em;display:flex;align-items:center;gap:8px">
            {p.title}
            {p.featured && <span style="color:var(--accent);font-size:12px">★</span>}
          </div>
          <div style="font-size:11px;color:var(--muted);margin-top:4px">{p.kind}</div>
        </div>
        <div class="sans" style="font-size:14px;color:var(--ink-soft);padding-top:4px">{p.tagline}</div>
        <div style="display:flex;flex-wrap:wrap;gap:4px;padding-top:4px">
          {p.stack.slice(0, 3).map(tech => (
            <span class="tm-chip">{tech}</span>
          ))}
          {p.stack.length > 3 && (
            <span style="font-size:10px;color:var(--muted);padding:3px 4px;font-family:'JetBrains Mono',monospace">+{p.stack.length - 3}</span>
          )}
        </div>
        <div class="proj-row-arrow" style="font-size:16px;color:var(--muted);padding-top:6px;transition:transform .25s,color .25s">→</div>
      </a>
    ))}
    <div style="border-top:1px solid var(--rule)" id="no-results" style="display:none">
      <div style="padding:60px 0;text-align:center;color:var(--muted);font-size:13px;display:none" id="empty-msg">
        <span style="color:var(--warn)">!</span> {lang === 'es' ? 'Sin resultados para ese filtro' : 'No results for that filter'}
      </div>
    </div>
  </section>

  <!-- GITHUB CTA -->
  <section style="padding:48px 56px 80px;border-top:1px solid var(--rule);background:var(--bg-dark)" class="proj-cta">
    <div class="tm-panel" style="padding:32px;display:flex;justify-content:space-between;align-items:center;gap:24px;flex-wrap:wrap">
      <div>
        <div style="font-size:11px;color:var(--muted);margin-bottom:8px">$ open github</div>
        <div class="tm-display" style="font-size:28px;color:var(--ink);letter-spacing:-.02em">
          {lang === 'es' ? '¿Quieres ver mi código?' : 'Want to see my code?'}
        </div>
        <div class="sans" style="font-size:14px;color:var(--ink-soft);margin-top:6px">
          {lang === 'es'
            ? 'Repositorios públicos, experimentos y configuraciones.'
            : 'Public repositories, experiments and configurations.'
          }
        </div>
      </div>
      <a href="https://github.com/HectorAlmonte" target="_blank" rel="noreferrer"
        style="padding:14px 24px;background:var(--accent);color:var(--bg);border-radius:4px;font-size:13px;font-weight:600;text-decoration:none;font-family:inherit">
        github.com/HectorAlmonte ↗
      </a>
    </div>
  </section>
</Layout>

<style>
  .proj-row:hover .proj-row-arrow { transform: translateX(4px); color: var(--accent) !important; }
  .proj-row:hover .proj-row-title { color: var(--accent) !important; }

  @media (max-width: 900px) {
    .proj-header, .proj-toolbar, .proj-list, .proj-cta { padding-left: 24px !important; padding-right: 24px !important; }
    .proj-header { padding-top: 40px !important; }
    .proj-cols { grid-template-columns: 1fr !important; }
    .proj-row-year { display: none; }
  }
</style>

<script define:vars={{ lang }}>
  document.addEventListener('astro:page-load', () => {
    const filterBtns  = document.querySelectorAll('.filter-chip');
    const rows        = document.querySelectorAll('.proj-row');
    const emptyMsg    = document.getElementById('empty-msg');

    function applyFilter(f) {
      filterBtns.forEach(btn => {
        const on = btn.dataset.filter === f;
        btn.style.background    = on ? 'var(--accent)' : 'transparent';
        btn.style.color         = on ? 'var(--bg)'     : 'var(--ink-soft)';
        btn.style.borderColor   = on ? 'var(--accent)' : 'var(--rule)';
        btn.style.fontWeight    = on ? '600'            : '400';
      });

      let visible = 0;
      rows.forEach(row => {
        const kind     = row.dataset.kind ?? '';
        const featured = row.dataset.featured === 'true';
        let show = false;
        if (f === 'all')      show = true;
        else if (f === 'featured') show = featured;
        else                  show = kind.includes(f);

        row.style.display = show ? 'grid' : 'none';
        if (show) visible++;
      });

      if (emptyMsg) emptyMsg.style.display = visible === 0 ? 'block' : 'none';
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all'));
    });
  });
</script>
