---
import Layout from '../../layouts/Layout.astro';
import { languages, type Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return languages.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const contactLinks = [
  { label: 'email',    value: 'hectoralmoten@gmail.com',              href: 'mailto:hectoralmoten@gmail.com',                      icon: '✉' },
  { label: 'github',   value: 'github.com/HectorAlmonte',             href: 'https://github.com/HectorAlmonte',                    icon: '⌥' },
  { label: 'linkedin', value: 'linkedin.com/in/hector-almonte',       href: 'https://www.linkedin.com/in/hector-almonte-788a4a212/', icon: '⊞' },
];

const pingLines = lang === 'es'
  ? ['Iniciando conexión...', 'Resolviendo hector.dev', 'Conexión establecida ✓', 'Tiempo de respuesta: &lt;24h']
  : ['Initiating connection...', 'Resolving hector.dev', 'Connection established ✓', 'Response time: &lt;24h'];
---

<Layout title={t.contact.title} description={t.meta.contact} lang={lang}>
  <section class="max-w-5xl mx-auto px-6 py-20">

    <!-- Header con ping animado -->
    <div class="mb-14">
      <p class="text-terminal-green text-sm mb-4">{t.contact.cmd}</p>

      <!-- Ping terminal block -->
      <div class="terminal-card max-w-md mb-8" id="ping-block">
        <div class="flex items-center gap-2 mb-3 pb-3 border-b border-terminal-border">
          <span class="w-2.5 h-2.5 rounded-full bg-terminal-red"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-terminal-yellow"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-terminal-green"></span>
          <span class="ml-2 text-xs text-terminal-muted">network — ping</span>
        </div>
        <div class="text-xs space-y-1 font-mono" id="ping-output">
          {pingLines.map((line, i) => (
            <p class="text-terminal-muted ping-line" style="opacity:0" set:html={line}></p>
          ))}
        </div>
      </div>

      <h1 class="text-4xl font-bold text-terminal-text">{t.contact.title}</h1>
      <div class="mt-3 flex items-center gap-3">
        <div class="h-px w-12 bg-terminal-green"></div>
        <div class="h-px flex-1 bg-gradient-to-r from-terminal-green/40 to-transparent"></div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-8">

      <!-- Form -->
      <div class="terminal-card" id="contact-form-card" style="opacity:0; transform: translateX(-20px)">
        <p class="text-xs text-terminal-muted mb-6">{t.contact.formLabel}</p>
        <!-- Success message (hidden by default) -->
        <div id="form-success" class="hidden text-center py-8">
          <p class="text-terminal-green text-2xl mb-2">✓</p>
          <p class="text-terminal-text text-sm font-semibold mb-1">
            {lang === 'es' ? '¡Mensaje enviado!' : 'Message sent!'}
          </p>
          <p class="text-terminal-muted text-xs">
            {lang === 'es' ? 'Te respondo en menos de 24h.' : "I'll reply within 24h."}
          </p>
        </div>

        <!-- Error message (hidden by default) -->
        <div id="form-error" class="hidden mb-4 p-3 rounded border border-terminal-red/40 bg-terminal-red/5">
          <p class="text-terminal-red text-xs">
            {lang === 'es' ? '⚠ Error al enviar. Intenta de nuevo o escríbeme directamente.' : '⚠ Send failed. Try again or contact me directly.'}
          </p>
        </div>

        <form id="contact-form" class="space-y-5">
          <div class="form-field">
            <label class="block text-xs text-terminal-green mb-1.5" for="name">
              <span class="text-terminal-muted">$</span> {t.contact.nameLabel}
            </label>
            <input
              id="name" name="name" type="text" required
              class="w-full bg-terminal-bg border border-terminal-border rounded px-3 py-2.5 text-sm text-terminal-text
                     focus:border-terminal-green focus:outline-none focus:shadow-[0_0_8px_rgba(57,211,83,0.25)]
                     transition-all placeholder:text-terminal-muted/40"
              placeholder={t.contact.namePlaceholder}
            />
          </div>

          <div class="form-field">
            <label class="block text-xs text-terminal-green mb-1.5" for="email">
              <span class="text-terminal-muted">$</span> {t.contact.emailLabel}
            </label>
            <input
              id="email" name="email" type="email" required
              class="w-full bg-terminal-bg border border-terminal-border rounded px-3 py-2.5 text-sm text-terminal-text
                     focus:border-terminal-green focus:outline-none focus:shadow-[0_0_8px_rgba(57,211,83,0.25)]
                     transition-all placeholder:text-terminal-muted/40"
              placeholder={t.contact.emailPlaceholder}
            />
          </div>

          <div class="form-field">
            <label class="block text-xs text-terminal-green mb-1.5" for="message">
              <span class="text-terminal-muted">$</span> {t.contact.messageLabel}
            </label>
            <textarea
              id="message" name="message" rows="5" required
              class="w-full bg-terminal-bg border border-terminal-border rounded px-3 py-2.5 text-sm text-terminal-text
                     focus:border-terminal-green focus:outline-none focus:shadow-[0_0_8px_rgba(57,211,83,0.25)]
                     transition-all resize-none placeholder:text-terminal-muted/40"
              placeholder={t.contact.messagePlaceholder}
            ></textarea>
          </div>

          <button
            id="submit-btn"
            type="submit"
            class="w-full py-3 bg-terminal-green text-terminal-bg font-semibold rounded text-sm
                   hover:bg-terminal-green/90 hover:shadow-[0_0_16px_rgba(57,211,83,0.3)]
                   transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed"
          >
            {t.contact.submit}
          </button>
        </form>
      </div>

      <!-- Right panel -->
      <div class="space-y-4" id="contact-info-panel" style="opacity:0; transform: translateX(20px)">

        <!-- Direct channels -->
        <div class="terminal-card">
          <p class="text-xs text-terminal-muted mb-5">{t.contact.directLabel}</p>
          <div class="space-y-4">
            {contactLinks.map(link => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-4 group p-2 rounded hover:bg-terminal-border/20 transition-colors"
              >
                <span class="w-8 h-8 rounded border border-terminal-border flex items-center justify-center
                             text-terminal-muted group-hover:border-terminal-green group-hover:text-terminal-green
                             transition-colors shrink-0 text-sm">
                  {link.icon}
                </span>
                <div class="min-w-0">
                  <p class="text-xs text-terminal-muted">{link.label}</p>
                  <p class="text-xs text-terminal-cyan group-hover:underline truncate">{link.value}</p>
                </div>
                <span class="ml-auto text-terminal-muted group-hover:text-terminal-green transition-colors text-xs shrink-0">→</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Availability -->
        <div class="terminal-card">
          <p class="text-xs text-terminal-muted mb-3">{t.contact.availLabel}</p>
          <div class="flex items-center gap-3 mb-3">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-terminal-green opacity-60"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-terminal-green"></span>
            </span>
            <span class="text-terminal-text text-sm">{t.contact.available}</span>
          </div>
          <p class="text-xs text-terminal-muted pl-6">{t.contact.responseTime}</p>
        </div>

        <!-- Location -->
        <div class="terminal-card">
          <p class="text-xs text-terminal-muted mb-3">// {lang === 'es' ? 'ubicación' : 'location'}</p>
          <p class="text-terminal-text text-sm">📍 Ilo, Moquegua, Perú</p>
          <p class="text-xs text-terminal-muted mt-1">UTC-5</p>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script>
  import { gsap } from 'gsap';

  // ── Ping animation ──────────────────────────────────────────
  const lines = document.querySelectorAll<HTMLElement>('.ping-line');
  lines.forEach((line, i) => {
    gsap.to(line, { opacity: 1, duration: 0.3, delay: 0.3 + i * 0.5 });
  });
  gsap.to(lines[lines.length - 1], {
    color: '#39d353',
    delay: 0.3 + (lines.length - 1) * 0.5 + 0.1,
  });

  // ── Entrance animations ─────────────────────────────────────
  gsap.to('#contact-form-card', {
    opacity: 1, x: 0, duration: 0.6, delay: 0.2, ease: 'power2.out',
  });
  gsap.to('#contact-info-panel', {
    opacity: 1, x: 0, duration: 0.6, delay: 0.4, ease: 'power2.out',
  });

  // ── EmailJS submit ───────────────────────────────────────────
  import emailjs from '@emailjs/browser';

  const SERVICE_ID  = 'service_2bt2yhj';
  const TEMPLATE_ID = 'template_qmzat3h';
  const PUBLIC_KEY  = '9I6ONW00vk1g5vjB0';

  emailjs.init(PUBLIC_KEY);

  const form     = document.getElementById('contact-form') as HTMLFormElement;
  const btn      = document.getElementById('submit-btn')   as HTMLButtonElement;
  const success  = document.getElementById('form-success') as HTMLElement;
  const errorBox = document.getElementById('form-error')   as HTMLElement;

  const originalLabel = btn.textContent ?? '';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    btn.disabled    = true;
    btn.textContent = '$ sending...';
    errorBox.classList.add('hidden');

    try {
      await emailjs.sendForm(SERVICE_ID, TEMPLATE_ID, form);
      form.classList.add('hidden');
      success.classList.remove('hidden');
    } catch {
      errorBox.classList.remove('hidden');
      btn.disabled    = false;
      btn.textContent = originalLabel;
    }
  });
</script>
