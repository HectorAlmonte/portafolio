---
import Layout from '../../../layouts/Layout.astro';
import { languages, type Lang } from '../../../i18n/translations';
import { projects } from '../../../data/projects';

export function getStaticPaths() {
  return languages.flatMap(lang =>
    projects.map(p => ({
      params: { lang, slug: p.slug },
      props: { project: p },
    }))
  );
}

const { lang } = Astro.params as { lang: Lang };
const { project } = Astro.props;

function t<T>(obj: { es: T; en: T }): T {
  return obj[lang as 'es' | 'en'];
}

const idx      = projects.findIndex(p => p.slug === project.slug);
const prevProj = idx > 0 ? projects[idx - 1] : null;
const nextProj = idx < projects.length - 1 ? projects[idx + 1] : null;

const stackCategories: Record<string, string> = {
  'TypeScript': 'lang', 'JavaScript': 'lang', 'Rust': 'lang', 'C#': 'lang',
  'React': 'frontend', 'Next.js': 'frontend', 'Next.js 14': 'frontend',
  'Next.js 16': 'frontend', 'Astro 5': 'frontend', 'TailwindCSS': 'frontend',
  'Node.js': 'backend', '.NET C#': 'backend', 'ASP.NET': 'backend',
  'PostgreSQL': 'data', 'SQL Server': 'data', 'SQLite': 'data', 'Prisma': 'data',
  'Drizzle ORM': 'data', 'Mapbox': 'infra', 'Docker': 'infra', 'PWA': 'infra',
  'Tesseract.js': 'lib', 'EmailJS': 'lib', 'NextAuth': 'lib', 'Workbox': 'lib',
};
const categoryLabel: Record<string, { es: string; en: string }> = {
  lang:     { es: 'lenguaje', en: 'language' },
  frontend: { es: 'frontend', en: 'frontend' },
  backend:  { es: 'backend',  en: 'backend' },
  data:     { es: 'datos',    en: 'data' },
  infra:    { es: 'infra',    en: 'infra' },
  lib:      { es: 'librería', en: 'library' },
  other:    { es: 'otro',     en: 'other' },
};
const stackGrouped = project.stack.reduce((acc, tech) => {
  const cat = stackCategories[tech] ?? 'other';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(tech);
  return acc;
}, {} as Record<string, string[]>);
---

<Layout title={project.title} description={t(project.tagline)} lang={lang}>

  <!-- HEADER -->
  <section style="padding:64px 56px 32px" class="pd-header">
    <div style="font-size:11px;color:var(--muted);margin-bottom:16px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
      <a href={`/${lang}/projects`}
        style="color:var(--muted);text-decoration:none;transition:color .15s"
        onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--muted)'">
        ← {lang === 'es' ? 'proyectos' : 'projects'}
      </a>
      <span style="opacity:.4">/</span>
      <span style="color:var(--accent)">{t(project.kind)}</span>
      <span style="opacity:.4">·</span>
      <span>{project.year}</span>
      <span style="flex:1"></span>
      <span style="display:flex;align-items:center;gap:6px">
        <span style="width:6px;height:6px;border-radius:50%;background:var(--accent);display:inline-block"></span>
        <span class="sans">{t(project.status)}</span>
      </span>
    </div>

    <h1 class="tm-display" style="font-size:clamp(48px,7vw,88px);margin:0;line-height:.95">
      <span style="color:var(--muted)">{'>'}</span>
      <span style="color:var(--ink)"> {project.title}</span>
      <span class="tm-cursor" style="color:var(--accent)"></span>
    </h1>

    <p class="sans" style="margin-top:24px;font-size:18px;color:var(--ink-soft);max-width:760px;line-height:1.55">
      {t(project.tagline)}
    </p>

    <div style="display:flex;gap:8px;margin-top:20px;flex-wrap:wrap">
      {project.stack.map(tech => <span class="tm-chip">{tech}</span>)}
    </div>
  </section>

  <!-- MOCKUP + IMPACT GRID -->
  <section style="padding:0 56px 40px;border-bottom:1px solid var(--rule);display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:stretch" class="pd-mockup">
    <!-- Terminal mockup -->
    <div class="tm-panel" style="padding:0;overflow:hidden">
      <div style="display:flex;align-items:center;gap:6px;padding:10px 14px;border-bottom:1px solid var(--rule);background:var(--bg-dark)">
        <span style="display:flex;gap:4px">
          <span style="width:9px;height:9px;border-radius:5px;background:#ff5f57;display:block"></span>
          <span style="width:9px;height:9px;border-radius:5px;background:#febc2e;display:block"></span>
          <span style="width:9px;height:9px;border-radius:5px;background:#28c840;display:block"></span>
        </span>
        <span style="margin-left:8px;font-size:11px;color:var(--muted)">bash — {project.slug}</span>
      </div>
      <pre style="margin:0;padding:18px 20px;font-size:12.5px;line-height:1.7;color:var(--ink-soft);overflow-x:auto;white-space:pre">{project.mockup.join('\n')}</pre>
    </div>

    <!-- Impact highlights -->
    <div style="display:flex;flex-direction:column;gap:16px">
      <div style="font-size:11px;color:var(--muted);margin-bottom:4px">
        <span style="color:var(--accent)">$</span> cat impact.md
      </div>
      {t(project.impact).map((metric, i) => (
        <div class="tm-panel impact-card" style={`padding:20px 22px;flex:1;display:flex;flex-direction:column;justify-content:center;border-left:2px solid var(--accent);border-radius:0 6px 6px 0`}>
          <div style="display:flex;gap:10px;align-items:flex-start">
            <span style="color:var(--accent);font-size:18px;font-weight:600;flex-shrink:0;margin-top:-1px">{String(i + 1).padStart(2, '0')}</span>
            <span class="sans" style="font-size:14px;color:var(--ink-soft);line-height:1.5">{metric}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- MAIN 2-COL -->
  <section style="padding:48px 56px 96px;display:grid;grid-template-columns:1fr 300px;gap:56px;align-items:start" class="pd-body">

    <!-- LEFT: narrative -->
    <article class="sans" style="font-size:16px;line-height:1.75;color:var(--ink-soft)">

      <div data-scroll="" style="margin-bottom:52px">
        <h2 class="tm-display" style="font-size:24px;color:var(--ink);margin:0 0 16px;letter-spacing:-.02em">
          <span style="color:var(--accent)">$</span> cat problem.md
        </h2>
        <p style="margin:0">{t(project.problem)}</p>
      </div>

      <div data-scroll="" style="margin-bottom:52px">
        <h2 class="tm-display" style="font-size:24px;color:var(--ink);margin:0 0 16px;letter-spacing:-.02em">
          <span style="color:var(--accent)">$</span> cat solution.md
        </h2>
        <p style="margin:0">{t(project.solution)}</p>
      </div>

      <div data-scroll="">
        <h2 class="tm-display" style="font-size:24px;color:var(--ink);margin:0 0 16px;letter-spacing:-.02em">
          <span style="color:var(--accent)">$</span> cat stack-decisions.md
        </h2>
        <div style="display:flex;flex-direction:column;gap:10px">
          {project.stackNotes.map(n => (
            <div class="tm-panel" style="padding:14px 18px;display:grid;grid-template-columns:160px 1fr;gap:16px;align-items:start">
              <span style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--accent);font-weight:500;line-height:1.6">{n.tech}</span>
              <span style="font-size:14px;color:var(--ink-soft);line-height:1.55">{t(n.reason)}</span>
            </div>
          ))}
        </div>
      </div>
    </article>

    <!-- RIGHT: impact + links -->
    <aside style="display:flex;flex-direction:column;gap:16px;position:sticky;top:80px">

      <div class="tm-panel" style="padding:20px" data-scroll="">
        <div style="font-size:11px;color:var(--muted);margin-bottom:14px">$ cat impact.md</div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px">
          {t(project.impact).map(metric => (
            <li style="display:flex;gap:10px;align-items:flex-start">
              <span style="color:var(--accent);margin-top:2px;flex-shrink:0;font-size:12px">▸</span>
              <span class="sans" style="font-size:13px;color:var(--ink-soft);line-height:1.5">{metric}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="tm-panel" style="padding:20px" data-scroll="">
        <div style="font-size:11px;color:var(--muted);margin-bottom:12px">$ git status</div>
        <div style="display:flex;align-items:center;gap:8px">
          <span style="width:7px;height:7px;border-radius:50%;background:var(--accent);display:block;flex-shrink:0"></span>
          <span class="sans" style="font-size:13px;color:var(--ink)">{t(project.status)}</span>
        </div>
      </div>

      <div class="tm-panel" style="padding:20px" data-scroll="">
        <div style="font-size:11px;color:var(--muted);margin-bottom:12px">$ ls --links</div>
        <div style="display:flex;flex-direction:column">
          <a href={project.github} target="_blank" rel="noreferrer"
            class="link-row"
            style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-top:1px solid var(--rule);text-decoration:none;color:var(--ink-soft);transition:color .15s">
            <span class="sans" style="font-size:13px">GitHub</span>
            <span style="color:var(--muted);transition:color .15s,transform .2s">↗</span>
          </a>
          {project.demo && (
            <a href={project.demo} target="_blank" rel="noreferrer"
              class="link-row"
              style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-top:1px solid var(--rule);text-decoration:none;color:var(--ink-soft);transition:color .15s">
              <span class="sans" style="font-size:13px">Demo en vivo</span>
              <span style="color:var(--muted);transition:color .15s,transform .2s">↗</span>
            </a>
          )}
          <div style="border-top:1px solid var(--rule)"></div>
        </div>
      </div>

      <!-- Stack breakdown by category -->
      <div class="tm-panel" style="padding:20px" data-scroll="">
        <div style="font-size:11px;color:var(--muted);margin-bottom:14px">$ cat stack.yml</div>
        <dl style="margin:0;display:flex;flex-direction:column;gap:10px;font-size:12px">
          {Object.entries(stackGrouped).map(([cat, techs]) => (
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
              <dt style="color:var(--muted);white-space:nowrap;padding-top:1px">{t(categoryLabel[cat] ?? categoryLabel.other)}</dt>
              <dd style="margin:0;text-align:right;display:flex;flex-wrap:wrap;justify-content:flex-end;gap:4px">
                {techs.map(tech => <span class="tm-chip" style="font-size:10px;padding:2px 7px">{tech}</span>)}
              </dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Project navigation -->
      <div class="tm-panel" style="padding:20px" data-scroll="">
        <div style="font-size:11px;color:var(--muted);margin-bottom:14px">$ ls ../</div>
        <div style="display:flex;flex-direction:column;gap:0">
          {prevProj && (
            <a href={`/${lang}/projects/${prevProj.slug}`}
              class="nav-proj-row"
              style="display:flex;align-items:center;gap:10px;padding:10px 0;border-top:1px solid var(--rule);text-decoration:none;color:var(--ink-soft);transition:color .15s;font-size:13px">
              <span style="color:var(--muted);flex-shrink:0">←</span>
              <div style="min-width:0">
                <div style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--accent);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{prevProj.title}</div>
                <div class="sans" style="font-size:11px;color:var(--muted);margin-top:1px">{t(prevProj.kind)}</div>
              </div>
            </a>
          )}
          {nextProj && (
            <a href={`/${lang}/projects/${nextProj.slug}`}
              class="nav-proj-row"
              style="display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 0;border-top:1px solid var(--rule);text-decoration:none;color:var(--ink-soft);transition:color .15s;font-size:13px">
              <div style="min-width:0">
                <div style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--accent);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{nextProj.title}</div>
                <div class="sans" style="font-size:11px;color:var(--muted);margin-top:1px">{t(nextProj.kind)}</div>
              </div>
              <span style="color:var(--muted);flex-shrink:0">→</span>
            </a>
          )}
          <div style="border-top:1px solid var(--rule)"></div>
        </div>
      </div>

      <a href={`/${lang}/projects`}
        style="display:block;text-align:center;padding:11px;border:1px solid var(--rule);border-radius:4px;color:var(--muted);text-decoration:none;font-size:12px;transition:border-color .2s,color .2s"
        onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'"
        onmouseout="this.style.borderColor='var(--rule)';this.style.color='var(--muted)'">
        ← {lang === 'es' ? 'todos los proyectos' : 'all projects'}
      </a>
    </aside>
  </section>
</Layout>

<style>
  .link-row:hover { color: var(--accent) !important; }
  .link-row:hover span:last-child { color: var(--accent) !important; transform: translateX(3px); }
  .link-row:first-child { border-top: 0 !important; }
  .nav-proj-row:hover { color: var(--accent) !important; }
  .nav-proj-row:first-child { border-top: 0 !important; }

  @media (max-width: 900px) {
    .pd-header, .pd-mockup, .pd-body {
      padding-left: 24px !important;
      padding-right: 24px !important;
    }
    .pd-header { padding-top: 40px !important; }
    .pd-mockup { grid-template-columns: 1fr !important; }
    .pd-body { grid-template-columns: 1fr !important; }
    aside[style*="position:sticky"] { position: static !important; }
  }
</style>
