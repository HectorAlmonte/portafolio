---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contacto — Hector Full Stack Developer">
  <section class="max-w-5xl mx-auto px-6 py-20">
    <!-- Header -->
    <div class="mb-12">
      <p class="text-terminal-green text-sm mb-2">$ ping hector</p>
      <h1 class="text-3xl font-bold text-terminal-text">Contacto</h1>
      <p class="text-terminal-muted mt-2 text-sm">
        Tiempo de respuesta promedio: &lt; 24h
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Form -->
      <div class="terminal-card">
        <p class="text-xs text-terminal-muted mb-6">// enviar mensaje</p>
        <form class="space-y-4" action="#" method="POST">
          <div>
            <label class="block text-xs text-terminal-muted mb-1" for="name">nombre</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              class="w-full bg-terminal-bg border border-terminal-border rounded px-3 py-2 text-sm text-terminal-text focus:border-terminal-green focus:outline-none transition-colors"
              placeholder="tu_nombre"
            />
          </div>
          <div>
            <label class="block text-xs text-terminal-muted mb-1" for="email">email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="w-full bg-terminal-bg border border-terminal-border rounded px-3 py-2 text-sm text-terminal-text focus:border-terminal-green focus:outline-none transition-colors"
              placeholder="tu@email.com"
            />
          </div>
          <div>
            <label class="block text-xs text-terminal-muted mb-1" for="message">mensaje</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full bg-terminal-bg border border-terminal-border rounded px-3 py-2 text-sm text-terminal-text focus:border-terminal-green focus:outline-none transition-colors resize-none"
              placeholder="Hola Hector, me interesa..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full py-2.5 bg-terminal-green text-terminal-bg font-semibold rounded text-sm hover:bg-terminal-green/90 transition-colors"
          >
            $ send message
          </button>
        </form>
      </div>

      <!-- Links -->
      <div class="space-y-4">
        <div class="terminal-card">
          <p class="text-xs text-terminal-muted mb-4">// canales directos</p>
          <div class="space-y-3">
            {[
              { label: 'email', value: 'hector@email.com', href: 'mailto:hector@email.com', color: 'text-terminal-cyan' },
              { label: 'github', value: 'github.com/hector', href: 'https://github.com', color: 'text-terminal-text' },
              { label: 'linkedin', value: 'linkedin.com/in/hector', href: 'https://linkedin.com', color: 'text-terminal-cyan' },
            ].map(link => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-3 group"
              >
                <span class="text-terminal-green text-xs w-16 shrink-0">{link.label}</span>
                <span class={`text-xs group-hover:underline ${link.color} transition-colors`}>{link.value}</span>
              </a>
            ))}
          </div>
        </div>

        <div class="terminal-card">
          <p class="text-xs text-terminal-muted mb-3">// disponibilidad</p>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-terminal-green animate-pulse"></span>
            <span class="text-terminal-text text-sm">Disponible para nuevos proyectos</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
